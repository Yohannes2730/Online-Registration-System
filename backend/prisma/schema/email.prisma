enum EmailStatus {
  PENDING
  SENT
  FAILED
}

model Email {
  id        String      @id @default(cuid())

  to        String
  from      String?

  subject   String
  body      String

  status    EmailStatus @default(PENDING)

  error     String?

  retries   Int         @default(0)

  createdAt DateTime    @default(now())
  sentAt    DateTime?
}

model Otp {
  id           String   @id @default(cuid())
  email        String
  otp          String
  expiresAt    DateTime
  verified     Boolean  @default(false)
  resendCount  Int      @default(0)
  lastResendAt DateTime?
  createdAt    DateTime @default(now())
}